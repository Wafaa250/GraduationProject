# Copy to frontend/.env and set your Google OAuth Web client ID.
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client IDs (Web application)
# Authorized JavaScript origins: http://localhost:5173 (and your production URL)
VITE_GOOGLE_CLIENT_ID=

# Backend (same OAuth client ID): set in environment or user secrets, not in committed appsettings:
#   Google__ClientId=your-client-id.apps.googleusercontent.com
