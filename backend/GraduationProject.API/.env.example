# Copy to appsettings.Development.json (gitignored) or set in your shell / IDE.
# ASP.NET Core uses double underscores: Email__Password maps to Email:Password.

# --- Brevo SMTP (recommended for SkillSwap) ---
Email__Enabled=true
Email__SmtpHost=smtp-relay.brevo.com
Email__SmtpPort=587
Email__UseSsl=true
Email__Username=your-brevo-account@email.com
Email__Password=xsmtpsib-your-brevo-smtp-key
Email__FromAddress=your-brevo-account@email.com
Email__FromName=SkillSwap

# Login link included in welcome emails
App__FrontendLoginUrl=http://localhost:5173/login

# Optional: OpenAI
# OpenAI__ApiKey=sk-...
